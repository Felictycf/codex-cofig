prefix_rule(pattern=["/bin/zsh", "-lc", "python3 - <<'PY'\nimport urllib.request, re\nurl='https://opencode.ai'\nhtml=urllib.request.urlopen(url,timeout=20).read().decode('utf-8','ignore')\nprint('len',len(html))\nfor pat in ['on-my-opencode','plugin','plugins','extensions','agent']:\n    if re.search(pat,html,re.I):\n        print('found',pat)\nPY"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "python3 - <<'PY'\nimport urllib.request, re\ncandidates=[\n 'https://opencode.ai/docs',\n 'https://opencode.ai/docs/introduction',\n 'https://opencode.ai/docs/plugins',\n 'https://opencode.ai/docs/agents',\n 'https://opencode.ai/docs/config',\n 'https://opencode.ai/docs/installation',\n 'https://opencode.ai/docs/community',\n 'https://opencode.ai/docs/cli',\n]\nfor url in candidates:\n    try:\n        html=urllib.request.urlopen(url,timeout=20).read().decode('utf-8','ignore')\n    except Exception as e:\n        print(url,'->',type(e).__name__,e)\n        continue\n    hit='on-my-opencode' in html\n    print(url,'len',len(html),'hit',hit)\n    if hit:\n        i=html.index('on-my-opencode')\n        print(html[max(0,i-80):i+80])\nPY"], decision="allow")
